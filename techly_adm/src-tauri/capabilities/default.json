{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "*"
  ],
  "permissions": [
    "core:default",
    "core:app:default",
    "core:window:default",
    "core:webview:default",
    "core:path:default",
    "core:event:default",
    "core:tray:default",
    "core:menu:default",
    "core:window:allow-start-dragging",
    "core:window:allow-close",
    "core:window:allow-minimize"
  ]
}